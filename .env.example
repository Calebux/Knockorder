# Copy to .env.local. Required for on-chain play (create/join match).

# --- Dojo (Knock Order world) ---
# After running knock_order/migrate.sh, manifest is copied to app/lib/dojo/manifest.json (world.address + contracts).
# Optional override: set world address here if you don't use the copied manifest.
NEXT_PUBLIC_DOJO_WORLD_ADDRESS=

# RPC URL (defaults to Cartridge Sepolia if unset)
NEXT_PUBLIC_DOJO_RPC_URL=https://api.cartridge.gg/x/starknet/sepolia
# Or: NEXT_PUBLIC_STARKNET_RPC_URL=https://api.cartridge.gg/x/starknet/sepolia
